<parameter-file instrument="IMAT" valid-from="2026-1-1">

  <component-link name="NorthBank" >

  <parameter name="alpha_0" type="number">
    <value val="&alpha_0;" />
  </parameter>
  <parameter name="beta_0" type="number">
    <value val="&beta_0;" />
  </parameter>
  <parameter name="beta_1" type="number">
    <value val="&beta_1;" />
  </parameter>
  <parameter name="sigma_0_sq" type="number">
    <value val="&sigma_0_sq;" />
  </parameter>
  <parameter name="sigma_1_sq" type="number">
    <value val="&sigma_1_sq;" />
  </parameter>
  <parameter name="sigma_2_sq" type="number">
    <value val="&sigma_2_sq;" />
  </parameter>

  <parameter name="BackToBackExponential:S" type="fitting">
    <formula eq="sqrt((&sigma_2_sq;)*centre^4+(&sigma_1_sq;)*centre^2+(&sigma_0_sq;))" unit="dSpacing" result-unit="TOF" />
  </parameter>
  <parameter name="BackToBackExponential:A" type="fitting">
    <formula eq="((&alpha_0;)/centre)" unit="dSpacing" result-unit="1/TOF" />
  </parameter>
  <parameter name="BackToBackExponential:B" type="fitting">
    <formula eq="((&beta_0;)+(&beta_1;)/(centre^4))" unit="dSpacing" result-unit="1/TOF" />
  </parameter>

  <parameter name="IkedaCarpenterPV:Alpha0" type="fitting">
  <formula eq="(&IC_Alpha0;)" unit="dSpacing" result-unit="TOF"/><fixed />
</parameter>

<parameter name="IkedaCarpenterPV:Alpha1" type="fitting">
  <formula eq="(&IC_Alpha1;)" unit="dSpacing" result-unit="TOF"/><fixed />
</parameter>

<parameter name="IkedaCarpenterPV:Beta0" type="fitting">
  <formula eq="(&IC_Beta0;)" unit="dSpacing" result-unit="TOF"/><fixed />
</parameter>

<parameter name="IkedaCarpenterPV:Kappa" type="fitting">
  <formula eq="(&IC_Kappa;)" unit="dSpacing" result-unit=""/><fixed />
</parameter>

  <parameter name="IkedaCarpenterPV:SigmaSquared" type="fitting">
    <formula eq="(&ICSigma2_sq;)*centre^4 + (&ICSigma1_sq;)*centre^2 + (&ICSigma0_sq;)"
             unit="dSpacing" result-unit="TOF^2" />
  </parameter>

  <parameter name="IkedaCarpenterPV:Gamma" type="fitting">
    <formula eq="(&ICGamma2;)*centre^2 + (&ICGamma1;)*centre + (&ICGamma0;)"
             unit="dSpacing" result-unit="TOF" />
  </parameter>

</component-link>

