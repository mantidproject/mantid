# Generate the workbench resources.py with pyrcc5 and rewrite its hard-coded
# `from PyQt5 import QtCore` to `from qtpy import QtCore` so the module loads under
# any binding. Mirrors qt/python/mantidqt/create_resources.cmake.in.
execute_process(
    COMMAND @PYRCC5_CMD@ @_qrc_files@
    OUTPUT_VARIABLE _res_py_content
)
string(REPLACE "from PyQt5 import QtCore" "from qtpy import QtCore" _res_py_content "${_res_py_content}")
file(WRITE @_output_res_py@ "${_res_py_content}")
