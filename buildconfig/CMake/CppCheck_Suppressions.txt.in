// suppress specific rule in specific files
// NOTE this needs the full path to the file, so would need this file to be generated by cmake
//      as different build servers have different starts to the file path

// -------- Project Wide ------------------

// Hide warnings about using explicit keyword constructors as we have "too many"
// and automated clang-tidy breaks a couple of implicit conversions we use widely
noExplicitConstructor

// Hide warnings about shadowed members for inheritance. Typically "m_log" with Algorithm
duplInheritedMember

// Hide unused functions, cppcheck does not consider headers, so many Qt overrides
// called by Qt will be marked as unused
unusedFunction

// We have some potentially uninitialized member vars but too many to fix at the moment
uninitMemberVar

// Around 100 of these exist where noConstructor is present
noConstructor

// Pre-processor Directives, such as #error, which are upstream anyway
preprocessorErrorDirective

// Cppcheck struggles with some inheritance chains, some of these might be true though
unusedPrivateFunction

// Since 2.13 Cppcheck reports how many checkers are used.
checkersReport

// Since 2.15 there are a lot of spurious information level defects to do with final classes
class_X_Y

// ----------------- Upstream libs ---------------

// All ANN files as they are upstream anyway
*:*${CMAKE_SOURCE_DIR}/Framework/Kernel/src/ANN/*

// LegacyNexus - quarantined C code, not to be modified
nullPointerOutOfMemory:${CMAKE_SOURCE_DIR}/Framework/LegacyNexus/src/napi.cpp
nullPointerOutOfMemory:${CMAKE_SOURCE_DIR}/Framework/LegacyNexus/src/napi5.cpp
nullPointerArithmeticOutOfMemory:${CMAKE_SOURCE_DIR}/Framework/LegacyNexus/src/napi5.cpp

// vms_convert.cpp: legacy VMS/VAX floating-point format conversion; struct members are bit-field layout
// definitions required for correct binary interpretation even when not individually named in expressions;
// vax_to_ieee_float/ieee_to_vax_float return types confuse cppcheck's const-propagation across bit-field unions
unusedStructMember:${CMAKE_SOURCE_DIR}/Framework/DataHandling/src/LoadRaw/vms_convert.cpp
knownConditionTrueFalse:${CMAKE_SOURCE_DIR}/Framework/DataHandling/src/LoadRaw/vms_convert.cpp

// ----------- Intentional dead code / known deferred bugs -----------
// fitresult is shadowed by a local variable and never updated; fixing it breaks tests (issue #13950)
knownConditionTrueFalse:${CMAKE_SOURCE_DIR}/Framework/Algorithms/src/FindPeaks.cpp
// det1 and det2 are both assigned from tracer.getDetectorResult(); cppcheck treats them as the same value
// but they are from separate traceFromSample() calls on a mutated tracer object
knownConditionTrueFalse:${CMAKE_SOURCE_DIR}/Framework/DataObjects/src/Peak.cpp
// startTime>m_roi.back() at line 97 is always false given the matching guard at line 86; the condition
// is retained in the else-if chain for clarity alongside the preceding front() and back() bounds checks
knownConditionTrueFalse:${CMAKE_SOURCE_DIR}/Framework/Kernel/src/TimeROI.cpp:97
// endX is reassigned to XValues.back() in the out-of-range branch but m_maxX is set directly afterward;
// the assignment is dead in that branch but kept for consistency with the warning message
unreadVariable:${CMAKE_SOURCE_DIR}/Framework/CurveFitting/src/Algorithms/Fit1D.cpp:379

// ----------- Internal cppcheck errors from cppcheck 2.18.1 -------------
internalError:${CMAKE_SOURCE_DIR}/Framework/DataObjects/inc/MantidDataObjects/MortonIndex/BitInterleaving.h:169

// ----------- False positives from cppcheck analysis limitations -----------

// m_response is populated by session.receiveResponse() before lines 167-169 and is not null at those points;
// the later if (m_response) guard at line 173 is a defensive check that cppcheck treats as evidence of possible null
nullPointerRedundantCheck:${CMAKE_SOURCE_DIR}/Framework/Kernel/src/GitHubApiHelper.cpp:167
nullPointerRedundantCheck:${CMAKE_SOURCE_DIR}/Framework/Kernel/src/GitHubApiHelper.cpp:168
nullPointerRedundantCheck:${CMAKE_SOURCE_DIR}/Framework/Kernel/src/GitHubApiHelper.cpp:169

// syntaxError: cppcheck cannot parse boost::python pointer-to-member-function operator syntax (&Class::operator+)
syntaxError:${CMAKE_SOURCE_DIR}/Framework/PythonInterface/mantid/kernel/src/Exports/V3D.cpp
syntaxError:${CMAKE_SOURCE_DIR}/Framework/PythonInterface/mantid/kernel/src/Exports/VMD.cpp

// templateRecursion: cppcheck hits its template instantiation depth limit for MDEvent slice templates
templateRecursion:${CMAKE_SOURCE_DIR}/Framework/MDAlgorithms/src/SliceMD.cpp

// unknownMacro: BOOST_PYTHON_MEMBER_FUNCTION_OVERLOADS is a boost.python macro cppcheck does not know
unknownMacro:${CMAKE_SOURCE_DIR}/Framework/PythonInterface/mantid/api/src/Exports/Run.cpp

// unknownMacro: Qt 'slots' keyword in ScriptEditor.h; defined empty in qt.cfg but still triggers unknownMacro
unknownMacro:${CMAKE_SOURCE_DIR}/qt/widgets/common/inc/MantidQtWidgets/Common/ScriptEditor.h

// pureVirtualCall: SLOT(runDialog()) expands to runDialog() via qt.cfg; this is a signal connection, not a real call
// primary cppcheck location is the pure virtual declaration in the header
pureVirtualCall:${CMAKE_SOURCE_DIR}/qt/widgets/common/inc/MantidQtWidgets/Common/QtPropertyBrowser/StringDialogEditor.h

// virtualCallInConstructor: detectorSetHook() is called indirectly from the constructor via setDecoratedDetector();
// PoldiDetectorDecorator::detectorSetHook() is empty and the call during construction is intentional hook design
// primary cppcheck location is the virtual function declaration in the header
virtualCallInConstructor:${CMAKE_SOURCE_DIR}/Framework/SINQ/inc/MantidSINQ/PoldiUtilities/PoldiDetectorDecorator.h

// cstyleCast: using declaration for a pointer-to-member-function type is misidentified as a C-style cast
cstyleCast:${CMAKE_SOURCE_DIR}/Framework/PythonInterface/mantid/api/src/CloneMatrixWorkspace.cpp

// publicAllocationError: m_mainLayout is owned by the Qt parent widget (QGridLayout(parent) transfers ownership);
// cppcheck does not model Qt parent-child memory management
publicAllocationError:${CMAKE_SOURCE_DIR}/qt/widgets/common/src/QtPropertyBrowser/qtbuttonpropertybrowser.cpp
publicAllocationError:${CMAKE_SOURCE_DIR}/qt/widgets/common/src/QtPropertyBrowser/qtgroupboxpropertybrowser.cpp

// operatorEqVarError: WorkspaceProperty::operator= intentionally copies only the workspace pointer value;
// m_optional and m_locking are property metadata (descriptors) and are not part of the assigned value
operatorEqVarError:${CMAKE_SOURCE_DIR}/Framework/API/inc/MantidAPI/WorkspaceProperty.hxx

// constVariablePointer / constParameterPointer: these pointers are passed to QList/QMap methods that require
// non-const pointer arguments (indexOf, find); making them pointer-to-const would not compile
constVariablePointer:${CMAKE_SOURCE_DIR}/qt/widgets/common/src/QtPropertyBrowser/qtgroupboxpropertybrowser.cpp
constParameterPointer:${CMAKE_SOURCE_DIR}/qt/widgets/common/src/QtPropertyBrowser/qtpropertybrowser.cpp
