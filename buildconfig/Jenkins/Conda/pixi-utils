#!/bin/bash

# Download and install pixi (if it isn't installed)
install_pixi() {
  # configure the path to where pixi will end up
  if [[ "$OSTYPE" != darwin* && -f "$HOME/.bashrc" ]]; then
    . "$HOME/.bashrc"
  else
    export PATH="$PATH:$HOME/.pixi/bin"
  fi

  # Specify pixi version
  if [[ -z "$1" || ! -f "$1/.pixi-version" ]]; then
    echo "ERROR: pixi version cannot be found"
    exit 1
  fi
  VERSION_PIXI=$(cat "$1/.pixi-version")
  # check if pixi is not installed
  if [ "$(command -v pixi)" ]; then
      echo "updating previously installed pixi"
      pixi self-update --no-progress --quiet --version $VERSION_PIXI
  else
    echo "install pixi"
    set +x # disable xtrace - don't care about details of pixi install
    curl -fsSL https://pixi.sh/install.sh | PIXI_VERSION=$VERSION_PIXI sh
    set -x # turn logging back on (enable xtrace)
    # source bashrc for updated PATH
    if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
    fi
    # Verify pixi was installed successfully
    if [ ! -f "$HOME/.pixi/bin/pixi" ]; then
      echo "ERROR: pixi installation failed"
      exit 1
    fi
  fi
  if which pixi ; then
    echo "using $(pixi --version)"
  else
    echo "ERROR: pixi command not found"
    exit 1
  fi
}
